{
  "name": "ledgerlift-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "LedgerLift local desktop shell",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "25.0.6"
  },
  "dependencies": {
    "tree-kill": "1.2.2",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.ledgerlift.desktop",
    "productName": "LedgerLift",
    "files": [
      "main.js",
      "preload.js"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
